# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database (PostgreSQL via Supabase)
# Local: postgresql://relay_user:relay_password@localhost:5432/relay_db
# Production: Get from Supabase dashboard
DATABASE_URL=postgresql://relay_user:relay_password@localhost:5432/relay_db

# Database Pool Configuration
DB_POOL_MAX=20

# JWT
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRY=24h

# Authentication Token (iOS app uses this)
AUTH_TOKEN=alfred_baby_monitor_2026

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info

# File Upload
MAX_FRAME_SIZE=2097152
MAX_AUDIO_CHUNK_SIZE=131072
AUDIO_BUFFER_SIZE=20

# Camera Timeout (seconds)
CAMERA_TIMEOUT=120

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# App URL
APP_URL=http://localhost:3000
