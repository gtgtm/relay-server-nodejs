{
  "name": "alfred-camera-relay-server",
  "version": "1.0.0",
  "description": "Production-ready Node.js relay server for Alfred Camera streaming",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "NODE_ENV=development nodemon src/index.js",
    "migrate": "node src/migrations/runMigrations.js",
    "seed": "node src/seeders/seedDatabase.js",
    "test": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write \"src/**/*.js\"",
    "db:reset": "npm run migrate && npm run seed"
  },
  "keywords": [
    "camera",
    "relay",
    "streaming",
    "webrtc",
    "security"
  ],
  "author": "Alfred Camera",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "3.20.0",
    "sequelize": "^6.35.2",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "babel-jest": "^29.7.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
